@prefix mda:   <http://mda.local/ontology/causal#> .
@prefix cco:   <http://www.ontologyrepository.com/CommonCoreOntologies/> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<http://mda.local/ontology/causal>
    a owl:Ontology ;
    rdfs:label "MDA Causal Ontology" ;
    rdfs:comment "Causal chain analysis ontology for Maritime Domain Awareness, aligned to CCO and PROV-O." ;
    owl:versionInfo "1.0.0" .

# ── Core Classes ─────────────────────────────────────────────

mda:CausalEvent
    a owl:Class ;
    rdfs:label "Causal Event" ;
    rdfs:comment "A discrete occurrence that participates in causal relationships." .

mda:CausalChain
    a owl:Class ;
    rdfs:subClassOf prov:Bundle ;
    rdfs:label "Causal Chain" ;
    rdfs:comment "A reified sequence of CausalEvents connected by causal relationships." .

mda:CausalPattern
    a owl:Class ;
    rdfs:label "Causal Pattern" ;
    rdfs:comment "A recurring template of causal relationships across multiple instances." .

mda:CausalPrediction
    a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Causal Prediction" ;
    rdfs:comment "A predicted future event generated by WorldFish simulation or pattern matching." .

mda:WorldFishSimulation
    a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "WorldFish Simulation" ;
    rdfs:comment "An agent-based simulation run that generates CausalPredictions." .

mda:MarketInstrument
    a owl:Class ;
    rdfs:label "Market Instrument" ;
    rdfs:comment "A tracked financial instrument (commodity, currency, equity, crypto)." .

# ── Causal Relationship Properties ───────────────────────────

mda:directlyCauses
    a owl:ObjectProperty ;
    rdfs:domain mda:CausalEvent ;
    rdfs:range  mda:CausalEvent ;
    rdfs:label  "directly causes" .

mda:enables
    a owl:ObjectProperty ;
    rdfs:domain mda:CausalEvent ;
    rdfs:range  mda:CausalEvent ;
    rdfs:label  "enables" .

mda:inhibits
    a owl:ObjectProperty ;
    rdfs:domain mda:CausalEvent ;
    rdfs:range  mda:CausalEvent ;
    rdfs:label  "inhibits" .

mda:correlatesWith
    a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain mda:CausalEvent ;
    rdfs:range  mda:CausalEvent ;
    rdfs:label  "correlates with" .

mda:grangerCauses
    a owl:ObjectProperty ;
    rdfs:subPropertyOf mda:directlyCauses ;
    rdfs:domain mda:CausalEvent ;
    rdfs:range  mda:CausalEvent ;
    rdfs:label  "Granger causes" .

mda:feedsBackInto
    a owl:ObjectProperty ;
    rdfs:domain mda:CausalEvent ;
    rdfs:range  mda:CausalEvent ;
    rdfs:label  "feeds back into" .

mda:predictedFrom
    a owl:ObjectProperty ;
    rdfs:domain mda:CausalPrediction ;
    rdfs:range  mda:CausalEvent ;
    rdfs:label  "predicted from" .

mda:affectsMarket
    a owl:ObjectProperty ;
    rdfs:domain mda:CausalEvent ;
    rdfs:range  mda:MarketInstrument ;
    rdfs:label  "affects market instrument" .

# ── Data Properties ──────────────────────────────────────────

mda:confidence
    a owl:DatatypeProperty ;
    rdfs:range xsd:float ;
    rdfs:label "confidence (0.0-1.0)" .

mda:eventType
    a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "event type code" .

mda:domain
    a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "operational domain" .

mda:lagMinDays
    a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "minimum lag in days" .

mda:lagMaxDays
    a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "maximum lag in days" .

mda:domainPair
    a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "cross-domain pair" .

mda:riskScore
    a owl:DatatypeProperty ;
    rdfs:range xsd:float ;
    rdfs:label "risk score (0-10)" .

mda:locationRegion
    a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "geographic region" .

mda:locationLat
    a owl:DatatypeProperty ;
    rdfs:range xsd:decimal ;
    rdfs:label "latitude" .

mda:locationLon
    a owl:DatatypeProperty ;
    rdfs:range xsd:decimal ;
    rdfs:label "longitude" .
