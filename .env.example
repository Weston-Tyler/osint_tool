# MDA System Environment Variables
# Copy to .env and update with strong passwords
# DO NOT COMMIT .env TO VERSION CONTROL

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password_32chars

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=mda_admin
MINIO_ROOT_PASSWORD=change_me_minio_password

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# GeoServer
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=change_me_geoserver_password

# Elasticsearch
ELASTIC_PASSWORD=change_me_elastic_password

# API
API_SECRET_KEY=change_me_jwt_secret_64chars

# External data source credentials
AISHUB_USERNAME=your_aishub_username
GFW_API_KEY=your_gfw_api_key

# Optional: Stardog (RDF/semantic layer)
STARDOG_URL=http://localhost:5820
STARDOG_DB=mda
STARDOG_USER=admin
STARDOG_PASSWORD=admin

# Optional: TAK Server
TAK_SERVER_HOST=localhost
TAK_SERVER_PORT=8089

# Resource tuning (defaults are Codespace-friendly; raise for production)
# Postgres
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_MAINTENANCE_WORK_MEM=128MB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAX_WAL_SIZE=1GB
# Memgraph memory limit in MiB
MEMGRAPH_MEMORY_LIMIT=2048
# Elasticsearch JVM heap
ES_JAVA_OPTS=-Xms1g -Xmx1g
# GeoServer JVM
GEOSERVER_JAVA_OPTS=-Xms512m -Xmx1g -Dorg.geotools.referencing.forceXY=true

# Optional: Keycloak (Phase 4)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_password
KEYCLOAK_DB_PASSWORD=change_me_keycloak_db_password
