# MDA System Environment Variables
# Copy to .env and update with strong passwords
# DO NOT COMMIT .env TO VERSION CONTROL

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password_32chars

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=mda_admin
MINIO_ROOT_PASSWORD=change_me_minio_password

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# GeoServer
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=change_me_geoserver_password

# Elasticsearch
ELASTIC_PASSWORD=change_me_elastic_password

# API
API_SECRET_KEY=change_me_jwt_secret_64chars

# External data source credentials
AISHUB_USERNAME=your_aishub_username
GFW_API_KEY=your_gfw_api_key

# Optional: Stardog (RDF/semantic layer)
STARDOG_URL=http://localhost:5820
STARDOG_DB=mda
STARDOG_USER=admin
STARDOG_PASSWORD=admin

# Optional: TAK Server
TAK_SERVER_HOST=localhost
TAK_SERVER_PORT=8089

# Resource tuning (defaults are Codespace-friendly; raise for production)
# Postgres
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_MAINTENANCE_WORK_MEM=128MB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAX_WAL_SIZE=1GB
# Memgraph memory limit in MiB
MEMGRAPH_MEMORY_LIMIT=2048
# Elasticsearch JVM heap
ES_JAVA_OPTS=-Xms1g -Xmx1g
# GeoServer JVM
GEOSERVER_JAVA_OPTS=-Xms512m -Xmx1g -Dorg.geotools.referencing.forceXY=true

# Optional: Keycloak (Phase 4)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_password
KEYCLOAK_DB_PASSWORD=change_me_keycloak_db_password

# =============================================================================
# DATA SOURCE API KEYS — fill in to enable each ingester
# Most have a free tier; the URL after each key shows where to register.
# Stubs are intentionally empty so unset checks (`if not KEY: skip`) work.
# =============================================================================

# ── Conflict / Events ───────────────────────────────────────────────────────
# ACLED — Armed Conflict Location & Event Data
# Register: https://acleddata.com/data-export-tool/
# Free tier: ~unlimited reads with attribution
ACLED_API_KEY=
ACLED_EMAIL=

# ── Economic ────────────────────────────────────────────────────────────────
# FRED — Federal Reserve Economic Data
# Register: https://fred.stlouisfed.org/docs/api/api_key.html
# Free tier: 120 requests/minute
FRED_API_KEY=

# ── Geospatial / Earth Observation ──────────────────────────────────────────
# NASA FIRMS — active fire detections (MODIS/VIIRS)
# Register: https://firms.modaps.eosdis.nasa.gov/api/area/
# Limit: 5000 requests / 10 minutes (= 8.3 req/sec sustained)
NASA_FIRMS_KEY=

# Copernicus Data Space — Sentinel-1 SAR (dark vessel detection)
# Register: https://dataspace.copernicus.eu/
# Free tier: large but quota-based
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# ── Aviation / ADS-B (relevant to Counter-UAS) ──────────────────────────────
# ADS-B Exchange — unfiltered aircraft tracking (paid)
# Register: https://www.adsbexchange.com/data/
ADSB_API_KEY=

# OpenSky Network — alternative to ADS-B Exchange (free with account)
# Register: https://opensky-network.org/
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ── Corporate / Ownership ──────────────────────────────────────────────────
# UK Companies House — beneficial owners + filings
# Register: https://developer.company-information.service.gov.uk/
# Free tier: 600 requests / 5 minutes
COMPANIES_HOUSE_API_KEY=

# SEC EDGAR — US securities filings
# No key required, but SEC mandates a User-Agent header with contact info
# Format: "Sample Company Name AdminContact@samplecompany.com"
SEC_EDGAR_USER_AGENT=

# Socrata Open Data — used by property_collector for US land registries
# Register: https://data.cityofchicago.org/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# ── Humanitarian ────────────────────────────────────────────────────────────
# WFP HungerMap — World Food Programme food security data
# Register: https://api.hungermapdata.org/
WFP_API_KEY=

# ReliefWeb — UN OCHA humanitarian reports
# No key required, but appname header recommended
# Register/request: https://reliefweb.int/help/api
RELIEFWEB_APPNAME=

# ── GDELT BigQuery (optional batch backfill) ────────────────────────────────
# GDELT live APIs (DOC/GEO/GKG/TV) need NO key.
# BigQuery is only needed for historical backfill at scale.
# Register: https://console.cloud.google.com/ (create a project, enable BigQuery)
GBQ_PROJECT_ID=
# Path on host that's mounted into the gdelt-bigquery container
GCP_CREDENTIALS_PATH=./credentials
GOOGLE_APPLICATION_CREDENTIALS=/credentials/gcp-key.json

# ── Counter-UAS Expansion (Phase 5) ─────────────────────────────────────────
# UN Comtrade — international trade flows by HS code (Pillar 2)
# Register: https://comtradeplus.un.org/
# Free tier: 500 requests/day, 100,000 records/request
UN_COMTRADE_KEY=

# US Census Foreign Trade — port-level US imports (Pillar 2)
# Register: https://api.census.gov/data/key_signup.html
# Free tier: 500 requests/day per IP without key, unlimited with key
US_CENSUS_TRADE_KEY=

# SAM.gov — US federal contract awards (Pillar 4)
# Register: https://sam.gov/data-services
SAM_GOV_KEY=

# DroneSec — commercial drone threat intelligence (Pillar 6)
# Register: https://www.dronesec.com/ (paid)
DRONESEC_API_KEY=

# Apify — TikTok/social scraping for cartel-drone TTP monitoring (Pillar 6)
# Register: https://apify.com/
APIFY_API_KEY=

# ── Social OSINT (optional, used by GDELT/Counter-UAS Pillar 6) ─────────────
# Twitter/X API — vessel/event monitoring
# Register: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=

# YouTube Data API — narco-drone video analysis
# Register: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# Telegram — channel monitoring (cartel coms)
# Register: https://my.telegram.org/auth
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Reddit — open source intelligence
# Register: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_SECRET=
REDDIT_USER_AGENT=mda-osint-research/0.1

# =============================================================================
# DATA DIRECTORY OVERRIDES (paths inside the worker containers)
# These almost never need changing; defaults are sane.
# =============================================================================

# OpenSanctions cache (mounted volume in corporate.yml)
OPENSANCTIONS_CACHE=/data/opensanctions

# GLEIF golden copy CSV download dir
GLEIF_DATA_DIR=/data/gleif

# ICIJ leaked data dir (Panama/Paradise/Pandora Papers)
ICIJ_DATA_DIR=/data/icij

# UK Land Registry overseas-company datasets (used by property_collector)
UK_OCOD_PATH=/data/corporate/uk_land_registry/OCOD.csv
UK_UKCOD_PATH=/data/corporate/uk_land_registry/UKCOD.csv

# Sentinel-1 SAR scene download dir
SAR_OUTPUT_DIR=/data/sentinel_sar

# =============================================================================
# RATE LIMITING / RETRY OVERRIDES (optional, defaults work for most uses)
# =============================================================================

# GFW (Global Fishing Watch) — already running, defaults shown
GFW_REQUEST_INTERVAL_SEC=1.5
GFW_MAX_RETRIES=5
GFW_BACKOFF_BASE_SEC=5.0

# GDELT GKG poll interval (15 min default = match GDELT publish cadence)
GKG_POLL_INTERVAL=900
